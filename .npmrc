# Metro (React Native's bundler) expects the flat node_modules layout
# that npm / yarn produce. pnpm's default symlinked layout keeps deps
# in `node_modules/.pnpm/<pkg>@<ver>/node_modules/<pkg>` and Metro's
# resolver can't walk that structure for transitive peer deps like
# `hoist-non-react-statics` from `react-native-gesture-handler`.
#
# node-linker=hoisted makes pnpm emit a flat tree identical to what
# npm would produce, while keeping workspace:* symlinks for monorepo
# packages. This single switch replaces the extraNodeModules Proxy
# hack, the blockList regex, and the public-hoist-pattern fallbacks.
node-linker=hoisted
auto-install-peers=true
strict-peer-dependencies=false
