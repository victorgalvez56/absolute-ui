{
  "name": "@absolute-ui/core",
  "version": "0.0.0",
  "description": "Core primitives for Absolute UI — liquid glass React Native design system.",
  "license": "MIT",
  "author": "Absolute UI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victorgalvez56/absolute-ui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/victorgalvez56/absolute-ui/issues"
  },
  "homepage": "https://github.com/victorgalvez56/absolute-ui#readme",
  "keywords": [
    "absolute-ui",
    "react-native",
    "liquid-glass",
    "design-system",
    "components",
    "ui",
    "glass",
    "blur"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "perf": "reassure",
    "perf:baseline": "reassure --baseline",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "sideEffects": false,
  "dependencies": {
    "@absolute-ui/a11y": "workspace:*",
    "@absolute-ui/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3.0",
    "react-native": ">=0.76.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react-native-reanimated": "^4.0.0",
    "reassure": "^1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
