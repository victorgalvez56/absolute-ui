{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "declarationMap": false,
    "sourceMap": false,
    "exactOptionalPropertyTypes": false
